{
  "name": "jauto",
  "version": "0.1.0",
  "private": true,
  "description": "Modern open-source replacement for JFLAP 7.1",
  "license": "MIT",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@jauto/web",
    "dev:desktop": "turbo run dev --filter=@jauto/desktop",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "turbo": "^2",
    "typescript": "^5.8",
    "prettier": "^3",
    "eslint": "^9",
    "vitest": "^3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "esbuild"]
  },
  "packageManager": "pnpm@10.18.2",
  "engines": {
    "node": ">=22"
  }
}
