{
  "name": "jauto",
  "version": "0.1.0",
  "private": true,
  "description": "Modern open-source replacement for JFLAP 7.1",
  "license": "MIT",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@jauto/web",
    "dev:desktop": "turbo run dev --filter=@jauto/desktop",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "prettier": "^3.8.3",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ],
    "overrides": {
      "electron@<38.8.6": ">=38.8.6",
      "electron@<39.8.1": ">=39.8.1",
      "electron@>=33.0.0-alpha.1 <39.8.5": ">=39.8.5",
      "electron@<39.8.5": ">=39.8.5"
    }
  },
  "packageManager": "pnpm@10.18.2",
  "engines": {
    "node": ">=22"
  }
}
